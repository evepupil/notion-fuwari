---
import type { GetStaticPaths } from "astro";
import PostPage from "../components/PostPage.astro";
import Pagination from "../components/control/Pagination.astro";
import { PAGE_SIZE } from "../constants/constants";
import MainGridLayout from "../layouts/MainGridLayout.astro";
import { getSortedPosts } from "../utils/content-utils";
import { t, getCurrentLocale } from "../i18n";

const locale = getCurrentLocale();

export const getStaticPaths = (async ({ paginate }) => {
	const localePosts = await getSortedPosts("zh-CN");
	return paginate(localePosts, { pageSize: PAGE_SIZE });
}) satisfies GetStaticPaths;
// https://github.com/withastro/astro/issues/6507#issuecomment-1489916992

const { page } = Astro.props;

const len = page.data.length;
const pageTitle = page.currentPage === 1 ? undefined : `中文博客第 ${page.currentPage} 页`;
const pageDescription = page.currentPage === 1
	? "分享 Serverless 架构、AI 应用开发、Cloudflare、前端工程、爬虫实践与学习方法的个人技术博客。"
	: `潮思Chaosyn中文博客第 ${page.currentPage} 页，继续浏览 Serverless、AI 应用、前端、爬虫与技术实践文章。`;
---

<MainGridLayout title={pageTitle} description={pageDescription} hideSidebar={true}>
    <h1 class="sr-only">{page.currentPage === 1 ? "潮思Chaosyn 技术博客" : pageTitle}</h1>
    <PostPage page={page} locale={locale}></PostPage>
    <Pagination class="mx-auto onload-animation" page={page} style=`animation-delay: calc(var(--content-delay) + ${(len)*50}ms)`></Pagination>
</MainGridLayout>
